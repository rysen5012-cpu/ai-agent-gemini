# 🔹 BigQuery client
bq_client = bigquery.Client()

def run_query(sql):
    try:
        query_job = bq_client.query(sql)
        results = query_job.result()
        rows = [dict(row) for row in results]
        return rows
    except Exception as e:
        return str(e)

